{
  "name": "gdgoc-adtu",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite dev --host $HOST --port $PORT",
    "build": "vite build",
    "preview": "vite preview --host $HOST --port $PORT",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write .",
    "lint": "prettier --check . && eslint .",
    "db:up": "podman-compose -f ./container-compose-dev.yaml up -d",
    "db:down": "podman-compose -f ./container-compose-dev.yaml down",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "shadcn:add": "pnpm dlx shadcn-svelte@latest add"
  },
  "dependencies": {
    "@fontsource/alice": "^5.2.8",
    "@fontsource/maple-mono": "^5.2.6",
    "@fontsource/poppins": "^5.2.7",
    "better-auth": "^1.3.34",
    "postgres": "^3.4.7"
  },
  "devDependencies": {
    "@deno/svelte-adapter": "^0.1.0",
    "@eslint/compat": "^2.0.0",
    "@eslint/js": "^9.39.1",
    "@internationalized/date": "^3.10.0",
    "@lucide/svelte": "^0.546.0",
    "@sveltejs/kit": "^2.48.5",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.17",
    "bits-ui": "^2.14.3",
    "clsx": "^2.1.1",
    "drizzle-kit": "^0.31.7",
    "drizzle-orm": "^0.44.7",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.13.0",
    "globals": "^16.5.0",
    "prettier": "^3.6.2",
    "prettier-plugin-svelte": "^3.4.0",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "svelte": "^5.43.6",
    "svelte-check": "^4.3.4",
    "tailwind-merge": "^3.4.0",
    "tailwind-variants": "^3.1.1",
    "tailwindcss": "^4.1.17",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.2",
    "vite-plugin-devtools-json": "^1.0.0"
  }
}
